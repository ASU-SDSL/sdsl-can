* text=auto

# Git metadata files
.gitattributes text eol=lf
.gitignore text eol=lf

# Source files
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf

# Build and config files
*.cmake text eol=lf
CMakeLists.txt text eol=lf
Kconfig text eol=lf
*.conf text eol=lf
*.overlay text eol=lf
*.dts text eol=lf
*.dtsi text eol=lf
*.proto text eol=lf

# Docs and metadata
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts
*.py text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary artifacts
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.bin binary
*.hex binary
*.elf binary
*.exe binary
